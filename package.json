{
  "name": "site-creator-vinext-starter",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "node scripts/run-vinext.mjs dev",
    "build": "node scripts/run-vinext.mjs build",
    "start": "node scripts/run-vinext.mjs start",
    "test": "npm run build && npm run test:unit && npm run test:bundle && npm run test:components",
    "test:unit": "node --test tests/application-activity.test.mjs tests/auth-transfer.test.mjs tests/job-imports.test.mjs tests/job-scale.test.mjs tests/job-validation.test.mjs tests/pagination.test.mjs tests/xlsx-export.test.mjs",
    "test:bundle": "node --test tests/bundle-budget.test.mjs",
    "test:components": "vitest run --config vitest.config.ts",
    "test:firebase:run": "vitest run --config vitest.firebase.config.ts",
    "test:firebase": "npx firebase-tools emulators:exec --only firestore --project job-tracker-a8bee \"npm run test:firebase:run\"",
    "test:all": "npm test && npm run test:firebase",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "firebase:emulators": "npx firebase-tools emulators:start --project job-tracker-a8bee",
    "firebase:deploy:rules": "npx firebase-tools deploy --only firestore:rules,firestore:indexes --project job-tracker-a8bee",
    "firebase:deploy:hosting": "npm run build && npx firebase-tools deploy --only hosting --project job-tracker-a8bee"
  },
  "dependencies": {
    "@firebase/app": "^0.15.1",
    "@firebase/auth": "^1.13.3",
    "@firebase/firestore": "^4.16.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "firebase": "^12.16.0",
    "jsdom": "^29.1.1",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "vitest": "^4.1.10",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
